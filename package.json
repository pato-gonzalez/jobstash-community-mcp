{
  "name": "jobstash-mcp",
  "version": "0.1.0",
  "description": "Community MCP server for JobStash.xyz — crypto-native job search for AI assistants (V0, Claude, Cursor, Continue, Zed, Windsurf).",
  "license": "MIT",
  "author": "Patricio Gonzalez",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "jobstash-mcp": "./dist/stdio.js"
  },
  "main": "./dist/stdio.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "pnpm sync:manifest && next build && tsup",
    "build:next": "pnpm sync:manifest && next build",
    "build:bin": "tsup",
    "sync:manifest": "node -e \"const fs=require('fs');fs.mkdirSync('public/.well-known',{recursive:true});fs.copyFileSync('mcp.json','public/mcp.json');fs.copyFileSync('mcp.json','public/.well-known/mcp-server.json');\"",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-types": "tsx scripts/generate-types.ts",
    "inspect:stdio": "npx -y @modelcontextprotocol/inspector node dist/stdio.js",
    "inspect:http": "npx -y @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "lru-cache": "^11.0.2",
    "mcp-handler": "^1.0.0",
    "next": "^15.5.0",
    "pino": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.18.0",
    "msw": "^2.6.6",
    "openapi-typescript": "^7.4.4",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.5"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "jobstash",
    "web3",
    "crypto-jobs",
    "v0",
    "vercel",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patster98/jobstash-community-mcp.git"
  },
  "homepage": "https://github.com/patster98/jobstash-community-mcp",
  "bugs": {
    "url": "https://github.com/patster98/jobstash-community-mcp/issues"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp"
    ]
  }
}
