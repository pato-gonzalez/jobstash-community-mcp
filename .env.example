# JobStash API
JOBSTASH_API_BASE_URL=https://middleware.jobstash.xyz
# Optional bearer for /public/jobs and /public/jobs/archive (paid/partner tier)
JOBSTASH_API_TOKEN=

# Cache TTLs (seconds)
JOBSTASH_CACHE_TTL_SECONDS=300
JOBSTASH_FILTERS_CACHE_TTL_SECONDS=3600

# HTTP behavior
JOBSTASH_REQUEST_TIMEOUT_MS=15000
JOBSTASH_MAX_RETRIES=3
JOBSTASH_USER_AGENT=jobstash-mcp/0.1.0

# Logging
LOG_LEVEL=info

# Optional bearer gating on the deployed MCP HTTP endpoint.
# When set, mcp-handler's withMcpAuth wraps the handler and clients must send
# `Authorization: Bearer <this value>`. Leave empty for public deployments.
MCP_BEARER_TOKEN=
